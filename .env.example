# doomerang-mp local stack — non-secret configuration.
# Copy to `.env` and edit. `.env` is gitignored.
#
# Secrets (postgres password, database URL, ggscale secret key) are NOT
# stored here — they live as files under ./secrets/ and are mounted
# into containers as `/run/secrets/<name>`. Seed them with:
#   make secrets-init
# then edit ./secrets/<name> to rotate. The default ggscale_secret_key
# is empty; bootstrap ggscale and write the minted key into the file.
#
# Game-client publishable key (GGSCALE_PUBLISHABLE_KEY) and the
# leaderboard ID (GGSCALE_LEADERBOARD_ID) are set in the host shell that
# launches the game binary — they are NOT secrets and don't live under
# ./secrets/.

# --- postgres connection (non-secret parts) --------------------------
# Used by both postgres itself and by `make secrets-init` when
# generating the default ./secrets/database_url.
POSTGRES_USER=ggscale
POSTGRES_DB=ggscale

# --- ggscale-server image -------------------------------------------
# Pin a tag, or point at a locally-built image.
# GGSCALE_IMAGE=buildwrangler/ggscale:latest

# --- doomerang-server -----------------------------------------------
# Address the game-server advertises via the fleet API. Use your LAN
# IP (e.g. 192.168.1.42:7373) if you want other devices to connect.
# DOOMERANG_PUBLIC_ADDRESS=localhost:7373
